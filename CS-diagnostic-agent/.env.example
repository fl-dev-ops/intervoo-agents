# LiveKit worker runtime
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Agent registration
AGENT_NAME=

# Model providers
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-5.1

# STT
SARVAM_API_KEY=
DEEPGRAM_API_KEY=
DEEPGRAM_STT_LANGUAGE=en-IN
DEEPGRAM_STT_MODEL=nova-3

# TTS
SARVAM_TTS_LANGUAGE=en-IN
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_TTS_SPEAKER=ishita
SARVAM_TTS_DICT_ID=p_fcfdd23b

# Knowledge Base (ChromaDB)
ENABLE_KNOWLEDGE_BASE=true
CHROMA_API_KEY=
CHROMA_TENANT=
CHROMA_DATABASE=
CHROMA_COLLECTION=
KNOWLEDGE_BASE_DEFAULT_LIMIT=10

# Observability
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# Session recording
ENABLE_RECORDING=true
DATABASE_URL=
AWS_S3_BUCKET=
AWS_DEFAULT_REGION=us-east-1
AWS_S3_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_FORCE_PATH_STYLE=false
S3_BASE_PREFIX=agents
WEBHOOK_URL=
EGRESS_POLL_TIMEOUT_SECONDS=45
