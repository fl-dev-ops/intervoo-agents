# LiveKit worker runtime
LIVEKIT_URL=wss://livekit.yourdomain.com
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Model providers
OPENROUTER_API_KEY=
OPENAI_API_KEY=
SARVAM_API_KEY=
DEEPGRAM_API_KEY=

# Optional observability
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://us.cloud.langfuse.com

# Optional recording / storage
ENABLE_RECORDING=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=
S3_BUCKET_NAME=
S3_RECORDING_PREFIX=
S3_TRANSCRIPT_PREFIX=
WEBHOOK_URL=
DATABASE_URL=

# Knowledge Base (ChromaDB) — used by all agents
CHROMA_API_KEY=
CHROMA_TENANT=
CHROMA_DATABASE=

# CS-diagnostic-agent
CS_DIAGNOSTIC_AGENT_NAME=diagnostic-agent
CS_DIAGNOSTIC_AGENT_IMAGE=intervoo/cs-diagnostic-agent:latest
CS_DIAGNOSTIC_AGENT_REPLICAS=6

# Pre-screen-agent
PRE_SCREEN_AGENT_NAME=pre-screen-agent
PRE_SCREEN_AGENT_IMAGE=intervoo/pre-screen-agent:latest
PRE_SCREEN_AGENT_REPLICAS=6

# Interview-agent
INTERVIEW_AGENT_NAME=interview-coaching-agent
INTERVIEW_AGENT_IMAGE=intervoo/interview-agent:latest
INTERVIEW_AGENT_REPLICAS=1

# Job-agent
JOB_AGENT_NAME=job-finder-agent
JOB_AGENT_IMAGE=intervoo/job-agent:latest
JOB_AGENT_REPLICAS=1
