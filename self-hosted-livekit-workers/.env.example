# Optional compose overrides for self-hosted LiveKit workers.
# Runtime credentials are loaded from each agent's own .env file.

CS_DIAGNOSTIC_AGENT_IMAGE=intervoo/cs-diagnostic-agent:latest
PRE_SCREEN_AGENT_IMAGE=intervoo/pre-screen-agent:latest
INTERVIEW_AGENT_IMAGE=intervoo/interview-agent:latest
JOB_AGENT_IMAGE=intervoo/job-agent:latest

CS_DIAGNOSTIC_AGENT_NAME=diagnostic-agent-dev
PRE_SCREEN_AGENT_NAME=pre-screen-agent
INTERVIEW_AGENT_NAME=interview-coaching-agent
JOB_AGENT_NAME=job-finder-agent

CS_DIAGNOSTIC_AGENT_REPLICAS=2
PRE_SCREEN_AGENT_REPLICAS=2
INTERVIEW_AGENT_REPLICAS=1
JOB_AGENT_REPLICAS=1
