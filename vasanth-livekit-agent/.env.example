# LiveKit project credentials
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
AGENT_NAME=intervoo-agent-dev-2

# Avatar provider: liveavatar, simli, or none
AVATAR_PROVIDER=liveavatar

# HeyGen LiveAvatar
LIVEAVATAR_API_KEY=
LIVEAVATAR_AVATAR_ID=

# Simli
SIMLI_API_KEY=
SIMLI_FACE_ID=
# Optional; Simli uses its default emotion when empty
SIMLI_EMOTION_ID=

# Recording and S3 session artifacts
ENABLE_RECORDING=true
AWS_S3_BUCKET=
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BASE_PREFIX=agents
EGRESS_START_TIMEOUT_SECONDS=15
EGRESS_POLL_TIMEOUT_SECONDS=45
S3_UPLOAD_TIMEOUT_SECONDS=15

# Optional session database and completion webhook
DATABASE_URL=
WEBHOOK_URL=

# Hedra is not supported because its Realtime Avatar service was shut down.
